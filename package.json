{
  "name": "freshdesk-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Freshdesk API integration with safety controls for write operations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "freshdesk-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "freshdesk",
    "model-context-protocol",
    "helpdesk",
    "ticketing"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
